		{
			"name": "4. Favorites Rates (FinanceService)",
			"item": [
				{
					"name": "GET /favorites-finance/{userId} - Курсы избранного",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// ============================================\r",
									"// 1. Регистрация (если пользователь не существует)\r",
									"// ============================================\r",
									"const registerRequest = {\r",
									"    url: 'http://localhost:5000/auth/register',\r",
									"    method: 'POST',\r",
									"    header: { 'Content-Type': 'application/json' },\r",
									"    body: {\r",
									"        mode: 'raw',\r",
									"        raw: JSON.stringify({\r",
									"            username: 'postmantest',\r",
									"            password: '123456'\r",
									"        })\r",
									"    }\r",
									"};\r",
									"\r",
									"pm.sendRequest(registerRequest, (err, res) => {\r",
									"    if (err) {\r",
									"        console.error('Register error:', err);\r",
									"    } else if (res.code === 200) {\r",
									"        console.log('✅ Пользователь создан');\r",
									"    } else if (res.code === 400) {\r",
									"        console.log('ℹ️ Пользователь уже существует');\r",
									"    }\r",
									"});\r",
									"\r",
									"// ============================================\r",
									"// 2. Логин (получаем токен и userId)\r",
									"// ============================================\r",
									"const loginRequest = {\r",
									"    url: 'http://localhost:5000/auth/login',\r",
									"    method: 'POST',\r",
									"    header: { 'Content-Type': 'application/json' },\r",
									"    body: {\r",
									"        mode: 'raw',\r",
									"        raw: JSON.stringify({\r",
									"            username: 'postmantest',\r",
									"            password: '123456'\r",
									"        })\r",
									"    }\r",
									"};\r",
									"\r",
									"pm.sendRequest(loginRequest, (err, res) => {\r",
									"    if (err) {\r",
									"        console.error('Login error:', err);\r",
									"        return;\r",
									"    }\r",
									"    \r",
									"    const json = res.json();\r",
									"    if (json.token) {\r",
									"        pm.collectionVariables.set('token', json.token);\r",
									"        \r",
									"        const base64Payload = json.token.split('.')[1];\r",
									"        const payload = JSON.parse(atob(base64Payload));\r",
									"        const userId = payload.sub;\r",
									"        pm.collectionVariables.set('userId', userId);\r",
									"        console.log('✅ UserId получен:', userId);\r",
									"    }\r",
									"});\r",
									"\r",
									"// ============================================\r",
									"// 3. Добавить 3 валюты для проверки (USD, EUR, GBP)\r",
									"// ============================================\r",
									"const currencies = ['USD', 'EUR', 'GBP'];\r",
									"\r",
									"currencies.forEach(code => {\r",
									"    const favoriteRequest = {\r",
									"        url: `http://localhost:5000/favorites/${code}`,\r",
									"        method: 'POST',\r",
									"        header: {\r",
									"            'Content-Type': 'application/json',\r",
									"            'Authorization': `Bearer ${pm.collectionVariables.get('token')}`\r",
									"        }\r",
									"    };\r",
									"    \r",
									"    pm.sendRequest(favoriteRequest, (err, res) => {\r",
									"        if (err) {\r",
									"            console.error(`Ошибка добавления ${code}:`, err);\r",
									"        } else if (res.code === 200) {\r",
									"            console.log(`✅ ${code} добавлена в избранное`);\r",
									"        } else if (res.code === 400) {\r",
									"            console.log(`ℹ️ ${code} уже в избранном`);\r",
									"        }\r",
									"    });\r",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:5000/favorites-finance/{{userId}}",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "5000",
							"path": [
								"favorites-finance",
								"{{userId}}"
							]
						}
					},
					"response": []
				},
